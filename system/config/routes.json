{
  "version": "2.0.0",
  "basePath": "/",
  "routes": [
    {
      "path": "/",
      "component": "home",
      "title": "الرئيسية",
      "auth": false,
      "layout": "default"
    },
    {
      "path": "/apps",
      "component": "app-manager",
      "title": "التطبيقات",
      "auth": true,
      "permissions": ["view:apps"],
      "layout": "default"
    },
    {
      "path": "/settings",
      "component": "settings-panel",
      "title": "الإعدادات",
      "auth": true,
      "permissions": ["manage:settings"],
      "layout": "admin"
    },
    {
      "path": "/admin",
      "component": "admin-dashboard",
      "title": "لوحة الإدارة",
      "auth": true,
      "permissions": ["access:admin"],
      "layout": "admin"
    },
    {
      "path": "/profile/:id",
      "component": "user-profile",
      "title": "الملف الشخصي",
      "auth": true,
      "dynamic": true,
      "layout": "default"
    },
    {
      "path": "/addons/:name",
      "component": "addon-viewer",
      "title": "الإضافة",
      "auth": true,
      "dynamic": true,
      "layout": "addon"
    }
  ],
  "middleware": [
    {
      "name": "auth",
      "enabled": true,
      "priority": 1
    },
    {
      "name": "logger",
      "enabled": true,
      "priority": 2
    },
    {
      "name": "rateLimiter",
      "enabled": true,
      "priority": 3
    }
  ],
  "notFound": {
    "component": "not-found",
    "title": "الصفحة غير موجودة"
  },
  "error": {
    "component": "error",
    "title": "خطأ في النظام"
  }
}